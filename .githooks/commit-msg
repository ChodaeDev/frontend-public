#!/bin/sh

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Merge 커밋은 검증 생략
if echo "$commit_msg" | grep -qE '^Merge '; then
  exit 0
fi

# 허용 접두사 + '~한다' 종결 (PR 번호 허용)
prefixes="feat|fix|style|refactor|docs|test"
pattern="^($prefixes): .+한다( \(#[0-9]+\))?$"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "\033[0;31m============================================================\033[0m"
  echo "\033[0;31mError\033[0m: 커밋 메시지가 컨벤션을 따르지 않습니다."
  echo "\033[0;34mExpected format\033[0m: <접두사>: <내용 (~한다)>"
  echo "\033[0;32m - 접두사\033[0m: feat, fix, style, refactor, docs, test"
  echo "\033[0;32m - 내용\033[0m: '~한다'로 끝나는 한글 문장"
  echo "\033[0;33mExample\033[0m: feat: 상담게시판 댓글 기능을 추가한다"
  echo "\033[0;33mExample\033[0m: fix: 모바일 입력 시 자동 확대를 방지한다"
  echo "\033[0;31m============================================================\033[0m"
  exit 1
fi

exit 0
